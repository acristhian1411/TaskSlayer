# Browser-visible API URL
PUBLIC_API_URL=http://localhost:8080/api

# Optional internal server-side URL (useful outside Docker)
API_URL=http://localhost:8080/api

# LM Studio OpenAI-compatible API base URL
# Use http://host.docker.internal:1234/v1 when fronten runs inside Docker.
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# Model identifier loaded in LM Studio
LMSTUDIO_MODEL=local-model

# Optional API key if LM Studio server requires auth
LMSTUDIO_API_KEY=
